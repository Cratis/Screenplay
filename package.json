{
    "private": true,
    "name": "screenplay-workspace",
    "workspaces": [
        "Source/Screenplay/Monaco/screenplay-language",
        "Source/Screenplay/Monaco/screenplay-editor"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "build": "yarn workspaces foreach -At run build",
        "lint": "yarn workspaces foreach -At run lint",
        "lint:ci": "yarn workspaces foreach -At run lint:ci",
        "compile": "yarn workspaces foreach -At run compile",
        "dev": "yarn workspace screenplay-editor dev",
        "g:lint": "cd $INIT_CWD && eslint --cache --quiet --fix",
        "g:lint:ci": "cd $INIT_CWD && eslint --cache --quiet"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@tony.ganchev/eslint-plugin-header": "^3.4.4",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "8.63.0",
        "@typescript-eslint/parser": "8.63.0",
        "@vitejs/plugin-react": "6.0.3",
        "eslint": "10.7.0",
        "eslint-plugin-react": "7.37.5",
        "globals": "17.7.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.63.0",
        "vite": "8.1.4"
    },
    "packageManager": "yarn@4.17.1"
}
