{
    "comments": {
        "lineComment": "//"
    },
    "brackets": [
        ["(", ")"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"" }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["\"", "\""]
    ],
    "folding": {
        "offSide": true
    },
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(module|feature|slice|policy|event|command|screen|projection|capture|reactor|constraint|layout|template|validate|produces|section)\\b.*$",
        "decreaseIndentPattern": "(?!)"
    }
}
